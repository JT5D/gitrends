# GitHub API token (optional — enables higher rate limits and API enrichment)
GITHUB_TOKEN=

# LLM provider for Swarm agents (optional)
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-20250514

# Module ports
GITPULSE_PORT=7401
GITDASH_PORT=7402
SWARM_PORT=7403

# Crawl interval in seconds (default 45)
CRAWL_INTERVAL=45

# Log level: debug | info | warn | error
LOG_LEVEL=info
